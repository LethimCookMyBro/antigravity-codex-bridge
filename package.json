{
  "name": "@lizmotia/ag-kit",
  "version": "0.1.1",
  "description": "Antigravity-inspired skills, agents, and workflows packaged for OpenAI Codex.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ag-kit": "./bin/ag-codex.js",
    "ag-codex": "./bin/ag-codex.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "pack:check": "npm pack --dry-run"
  },
  "files": [
    ".agents/.shared/**/*.csv",
    ".agents/.shared/**/*.md",
    ".agents/.shared/**/*.py",
    ".agents/agents/**/*.md",
    ".agents/scripts/**/*.md",
    ".agents/scripts/**/*.py",
    ".agents/scripts/**/*.sh",
    ".agents/skills/**/*.md",
    ".agents/skills/**/*.py",
    ".agents/skills/**/*.yaml",
    ".agents/workflows/**/*.md",
    "bin/ag-codex.js",
    "AGENT_FLOW.md",
    "PUBLISHING.md",
    "UPDATELIST.md",
    "SKILLS_AND_WORKFLOWS.md",
    "SKILLS_AND_WORKFLOWS_TH.md",
    "README.md",
    "README(th).md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LethimCookMyBro/antigravity-codex-bridge.git"
  },
  "homepage": "https://github.com/LethimCookMyBro/antigravity-codex-bridge#readme",
  "bugs": {
    "url": "https://github.com/LethimCookMyBro/antigravity-codex-bridge/issues"
  },
  "keywords": [
    "codex",
    "openai-codex",
    "agents",
    "skills",
    "workflow",
    "antigravity"
  ]
}
